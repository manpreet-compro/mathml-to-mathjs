  "type": "module",
  "description": "Convert MathML strings to mathjs-compatible expression strings. Works in both browser and Node.js.",
  "keywords": [
    "mathml",
    "mathjs",
    "math",
    "expression",
    "parser",
    "converter"
  ],
  "author": "manpreet-compro",

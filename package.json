  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@xmldom/xmldom": "^0.9.4",
    "jest": "^29.7.0",
    "rollup": "^4.18.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "@xmldom/xmldom": "^0.9.4"
  },
